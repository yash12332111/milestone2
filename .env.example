# Mutual Fund FAQ Assistant — Environment Variables
# ===================================================

# Groq API key (required for LLM Generation)
GROQ_API_KEY=gsk_your-groq-key-here

# ChromaDB persistence directory (default: ./data/chroma_db)
CHROMA_PERSIST_DIR=./data/chroma_db

# SQLite database path for chat threads (default: ./data/threads.db)
SQLITE_DB_PATH=./data/threads.db

# Logging level
LOG_LEVEL=INFO
